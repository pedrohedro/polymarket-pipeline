# Classification engine: auto | anthropic | openai | local
#   auto  -> use Anthropic if a key is set, otherwise the offline local engine
#   local -> no API key or network required (heuristic engine)
CLASSIFIER_ENGINE=auto

# Anthropic (required only if CLASSIFIER_ENGINE uses anthropic/auto with a key)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — alternative LLM engine; set CLASSIFIER_ENGINE=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
EDGE_THRESHOLD=0.10

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
MATERIALITY_THRESHOLD=0.6
SPEED_TARGET_SECONDS=5
