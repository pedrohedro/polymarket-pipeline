# AI provider
# Options: codex, openai, openrouter, anthropic, generic
AI_PROVIDER=codex
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT=60
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.1

# Codex CLI/OAuth provider
# Run `codex login` once, then keep AI_PROVIDER=codex.
CODEX_BIN=codex
CODEX_MODEL=
CODEX_PROFILE=
CODEX_TIMEOUT=60

# OpenAI-compatible providers
OPENAI_API_KEY=
OPENAI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Polymarket-Pipeline

# Anthropic provider (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
EDGE_THRESHOLD=0.10

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
MATERIALITY_THRESHOLD=0.6
SPEED_TARGET_SECONDS=5
